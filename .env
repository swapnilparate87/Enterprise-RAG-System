# FREE VERSION Configuration - No API Keys Needed! 🎉

# Application Settings
APP_NAME=OpenRAG-Studio
APP_VERSION=1.0.0
DEBUG=True
LOG_LEVEL=INFO

# API Settings
API_V1_PREFIX=/api/v1
MAX_UPLOAD_SIZE=10485760  # 10MB

# FREE LLM Configuration (Ollama - runs locally)
# Install: https://ollama.ai
OLLAMA_MODEL=mistral
# Other options: llama2, phi, codellama
# See all: https://ollama.ai/library

# FREE Embeddings (HuggingFace - runs locally)
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Other options: 
# - all-mpnet-base-v2 (better quality, slower)
# - paraphrase-MiniLM-L3-v2 (faster, smaller)

# Vector Database (ChromaDB - FREE, local)
CHROMA_PERSIST_DIRECTORY=./chroma_db

# RAG Settings
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_K=5

# Database (SQLite - FREE, local)
DATABASE_URL=sqlite:///./rag_system.db

# Security
SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Optional: HuggingFace API (for cloud deployment)
# Get free key from: https://huggingface.co/settings/tokens
# HUGGINGFACE_API_KEY=your_key_here

# System Requirements Check
# RAM: 8GB minimum (16GB recommended for Mistral)
# Disk: 10GB free space
# Internet: Only for initial model download

OLLAMA_MODEL=qwen2:1.5b
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHUNK_SIZE=500
CHUNK_OVERLAP=100
RETRIEVAL_K=6
DEBUG=True
LOG_LEVEL=INFO
 