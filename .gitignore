# ============================================
# Enterprise RAG System - .gitignore
# ============================================

# Virtual Environment
RAG_System/
venv/
env/
.venv/
*.env/

# Environment Variables (NEVER commit this!)
env
.env.local
.env.production
.env.*

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd
.Python

# Distribution / Packaging
build/
dist/
*.egg-info/
*.egg
wheels/

# Vector Store / Chroma Data
chroma_db/
chroma/
*.db
*.sqlite
*.sqlite3

# Data Files (documents you upload for RAG)
data/documents/*
data/test_cases/*
!data/documents/.gitkeep
!data/test_cases/.gitkeep

# Jupyter Notebooks checkpoints
notebooks/.ipynb_checkpoints/
.ipynb_checkpoints/
*.ipynb_checkpoints

# Logs
*.log
logs/
log/

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# IDE / Editor
.vscode/settings.json
.idea/
*.swp
*.swo
*~

# Testing
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# MyPy
.mypy_cache/
.dmypy.json

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Model files (too large for GitHub)
*.bin
*.pt
*.pth
*.gguf
*.onnx